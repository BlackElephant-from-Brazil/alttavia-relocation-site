HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
CORS_ORIGIN=http://localhost:3000
STRAPI_PLUGIN_I18N_INIT_LOCALE_CODE=en

# Manual translation plugin: strapi-llm-translator
# The plugin reads LLM_TRANSLATOR_LLM_API_KEY. If it is empty, config/plugins.ts falls back to OPENAI_API_KEY.
LLM_TRANSLATOR_LLM_API_KEY=
STRAPI_ADMIN_LLM_TRANSLATOR_LLM_BASE_URL=https://api.openai.com/v1
STRAPI_ADMIN_LLM_TRANSLATOR_LLM_MODEL=gpt-4o-mini
STRAPI_ADMIN_LLM_TRANSLATOR_AZURE_API_VERSION=

# Automatic post translation service
TRANSLATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
AUTO_TRANSLATE_ON_PUBLISH=false
TRANSLATION_CREATE_AS_DRAFT=true
STRAPI_BOOTSTRAP_SEED=false
