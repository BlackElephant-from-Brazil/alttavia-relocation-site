{
  "name": "alttavia-relocation-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:cms": "npm --prefix cms run develop",
    "build": "npm run build:web",
    "build:web": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=4096\" next build",
    "build:cms": "npm --prefix cms run build",
    "start": "npm run start:web",
    "start:web": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "start:cms": "npm --prefix cms run start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "seed:cms": "npm --prefix cms run seed"
  },
  "dependencies": {
    "cross-env": "10.1.0",
    "lucide-react": "^0.511.0",
    "next": "15.4.11",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.4.11",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
